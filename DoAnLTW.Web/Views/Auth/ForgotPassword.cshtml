@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quen mat khau";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="mb-4">
            <span class="badge-soft">Khoi phuc tai khoan</span>
            <h2 class="mt-3 mb-2">Nhan ma dat lai mat khau</h2>
            <p class="text-muted mb-0">Nhap email da dang ky. He thong se gui ma xac thuc de ban dat mat khau moi.</p>
        </div>

        <form asp-action="ForgotPassword" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="col-12">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <button class="btn btn-soft-primary w-100 btn-lg" type="submit">Gui ma xac thuc</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
