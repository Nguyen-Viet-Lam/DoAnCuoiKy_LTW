@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="mb-4">
            <span class="badge-soft">Chào mừng bạn quay lại</span>
            <h2 class="mt-3 mb-2">Đăng nhập vào tài khoản</h2>
            <p class="text-muted mb-0">Tiếp tục theo dõi ví tiền, giao dịch gần đây và các cảnh báo ngân sách của bạn.</p>
        </div>

        <form asp-action="Login" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="col-12">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control form-control-lg" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="col-12 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>
                <a asp-action="ForgotPassword" class="link-soft">Quên mật khẩu?</a>
            </div>
            <div class="col-12">
                <button class="btn btn-soft-primary w-100 btn-lg" type="submit">Đăng nhập</button>
            </div>
        </form>

        @if (ViewBag.PendingEmail is string pendingEmail)
        {
            <form asp-action="ResendOtp" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@pendingEmail" />
                <input type="hidden" name="purpose" value="Register" />
                <button class="btn btn-outline-soft btn-sm" type="submit">Gửi lại mã xác thực</button>
            </form>
        }

        <p class="text-muted mt-4 mb-0">
            Chưa có tài khoản?
            <a asp-action="Register" class="link-soft">Tạo tài khoản mới</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
