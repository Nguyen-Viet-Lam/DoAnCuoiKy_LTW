@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Dat lai mat khau";
}

<div class="auth-wrap">
    <div class="auth-card auth-card-wide">
        <div class="mb-4">
            <span class="badge-soft">Dat mat khau moi</span>
            <h2 class="mt-3 mb-2">Cap nhat mat khau</h2>
            <p class="text-muted mb-0">Nhap ma xac thuc vua nhan cung mat khau moi de hoan tat khoi phuc tai khoan.</p>
        </div>

        <form asp-action="ResetPassword" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="col-12">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-lg" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control form-control-lg otp-input" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control form-control-lg" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <button class="btn btn-soft-primary w-100 btn-lg" type="submit">Luu mat khau moi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
