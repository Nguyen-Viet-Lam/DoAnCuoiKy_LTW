@model ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<section class="row g-4">
    <div class="col-xxl-4 col-xl-5">
        <div class="soft-card text-center">
            <div class="profile-avatar-preview">
                @if (!string.IsNullOrWhiteSpace(Model.AvatarPath))
                {
                    <img src="@Model.AvatarPath" alt="Avatar" />
                }
                else
                {
                    <span>@(string.IsNullOrWhiteSpace(Model.DisplayName) ? "U" : Model.DisplayName[..1].ToUpper())</span>
                }
            </div>
            <h3 class="mt-3 mb-1">@Model.DisplayName</h3>
            <p class="text-muted mb-0">@Model.Email</p>
            <div class="profile-meta">
                <div>
                    <span>Ngay tham gia</span>
                    <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xxl-8 col-xl-7">
        <div class="soft-card" id="profile-form">
            <div class="section-title">
                <div>
                    <h3>Cap nhat ho so</h3>
                    <p>Thay doi ten hien thi, email, avatar va mat khau.</p>
                </div>
            </div>

            <form asp-action="Index" method="post" enctype="multipart/form-data" class="row g-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="col-md-6">
                    <label asp-for="DisplayName" class="form-label"></label>
                    <input asp-for="DisplayName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="AvatarFile" class="form-label"></label>
                    <input asp-for="AvatarFile" class="form-control" />
                </div>
                <div class="col-12" id="password-form">
                    <div class="form-divider-title">
                        <h4>Doi mat khau</h4>
                        <p>Bo trong neu ban chi muon cap nhat thong tin ca nhan.</p>
                    </div>
                </div>
                <div class="col-12">
                    <label asp-for="CurrentPassword" class="form-label"></label>
                    <input asp-for="CurrentPassword" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                </div>
                <div class="col-12 d-grid">
                    <button class="btn btn-soft-primary" type="submit">Luu thay doi</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
