@model BudgetsPageViewModel
@{
    ViewData["Title"] = "Ngân sách";
}

<section class="row g-4">
    <div class="col-xl-5 col-xxl-4">
        <div class="soft-card sticky-panel">
            <div class="section-title">
                <div>
                    <h3>@(Model.Form.Id.HasValue ? "Sua han muc" : "Thiet lap han muc")</h3>
                    <p>Dinh muc chi tieu theo thang cho tung danh muc.</p>
                </div>
            </div>

            <form asp-action="Save" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input asp-for="Form.Id" type="hidden" />
                <div class="col-12">
                    <label asp-for="Form.CategoryId" class="form-label"></label>
                    <select asp-for="Form.CategoryId" class="form-select" asp-items="@(new SelectList(Model.Form.CategoryOptions, "Value", "Text"))"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Form.Month" class="form-label"></label>
                    <input asp-for="Form.Month" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Form.Year" class="form-label"></label>
                    <input asp-for="Form.Year" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Form.LimitAmount" class="form-label"></label>
                    <input asp-for="Form.LimitAmount" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Form.AlertThresholdPercent" class="form-label"></label>
                    <input asp-for="Form.AlertThresholdPercent" class="form-control" />
                </div>
                <div class="col-12 d-grid">
                    <button class="btn btn-soft-primary" type="submit">Luu ngan sach</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-xl-7 col-xxl-8">
        <div class="grid-cards mb-4">
            <article class="soft-card stat-card">
                <span>Tong han muc</span>
                <strong>@Model.TotalBudget.ToString("N0") VND</strong>
            </article>
            <article class="soft-card stat-card">
                <span>Tong da chi</span>
                <strong>@Model.TotalSpent.ToString("N0") VND</strong>
            </article>
        </div>

        <div class="soft-card">
            <div class="section-title">
                <div>
                    <h3>Tien do ngan sach</h3>
                    <p>Theo doi bang thanh phan tram cho tung danh muc.</p>
                </div>
            </div>
            @if (Model.Budgets.Any())
            {
                @foreach (var item in Model.Budgets)
                {
                    <div class="budget-line">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <strong>@item.CategoryName</strong>
                                <div class="text-muted small">@item.MonthLabel</div>
                            </div>
                            <div class="text-end">
                                <strong>@item.UsagePercent.ToString("0.#")%</strong>
                                <div class="text-muted small">@item.SpentAmount.ToString("N0") / @item.LimitAmount.ToString("N0") VND</div>
                            </div>
                        </div>
                        <div class="progress soft-progress">
                            <div class="progress-bar" style="width:@Math.Min(item.UsagePercent, 100)% ; background:@item.ColorHex"></div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <a class="btn btn-outline-soft btn-sm" asp-action="Index" asp-route-editId="@item.Id">Sua</a>
                            <form asp-action="Delete" method="post" data-confirm="Ban co chac muon xoa ngan sach nay khong?">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-soft-danger btn-sm" type="submit">Xoa</button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <h4>Chua co ngan sach nao</h4>
                    <p>Hay thiet lap han muc cho tung danh muc de theo doi muc chi tieu trong thang.</p>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
